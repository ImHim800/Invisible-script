bc.CornerRadius = UDim.new(0, 8)

local dr, ds, sp, di
tb.InputBegan:Connect(function(i)
    if not dr and (i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch) then
        dr = true
        di = i
        ds = i.Position
        sp = mf.Position
        
        local changedConn
        changedConn = i.Changed:Connect(function()
            if i.UserInputState == Enum.UserInputState.End then
                dr = false
                di = nil
                if changedConn then
                    changedConn:Disconnect()
                    changedConn = nil
                end
            end
        end)
    end
end)

uis.InputChanged:Connect(function(i)
    if dr and i == di then
        local d = i.Position - ds
        mf.Position = UDim2.new(sp.X.Scale, sp.X.Offset + d.X, sp.Y.Scale, sp.Y.Offset + d.Y)
    end
end)

local function cleanUI()
    btn.Text = "Invisible: OFF"
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
end

local function cleanGhost()
    if ghost then 
        ghost:Destroy() 
        ghost = nil 
    end
    if loop then loop:Disconnect() loop = nil end
    staticPos = nil
    lastSafeCFrame = nil
    realRoot = nil
    ghostRoot = nil
    cam.CameraType = Enum.CameraType.Custom
    cam.FieldOfView = 70
end

local function cleanChar()
    local char = lp.Character
    local r = char and char:FindFirstChild("HumanoidRootPart")
    local h = char and char:FindFirstChild("Humanoid")
    
    local targetCFrame = (ghostRoot and ghostRoot.CFrame) or lastSafeCFrame
    
    if r and targetCFrame then
        r.CFrame = targetCFrame
        r.AssemblyLinearVelocity = Vector3.zero
        r.AssemblyAngularVelocity = Vector3.zero
    end
    
    if char then
        for _, v in char:GetChildren() do
            if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
                v.CanCollide = true
            elseif v:IsA("Accessory") then
                local handle = v:FindFirstChild("Handle")
                if handle then handle.CanCollide = false end
            end
        end
    end
    
    if h then
        cam.CameraSubject = h
        h.PlatformStand = false
        h:SetStateEnabled(Enum.HumanoidStateType.Climbing, true)
        h:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
        h:SetStateEnabled(Enum.HumanoidStateType.Running, true)
        h.AutoRotate = true
        h.Jump = false
        h:ChangeState(Enum.HumanoidStateType.GettingUp)
    end
end

local function reset()
    active = false
    cleanUI()
    cleanChar()
    cleanGhost()
end

btn.MouseButton1Click:Connect(function()
    active = not active
    local char = lp.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChild("Humanoid") then return end
    local r = char.HumanoidRootPart
    local h = char.Humanoid
    
    if active then
        btn.Text = "Invisible: ON"
        btn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        
        realRoot = r
        staticPos = CFrame.new(0, ws.FallenPartsDestroyHeight + 100, 0)
        lastSafeCFrame = r.CFrame
        
        char.Archivable = true
        ghost = char:Clone()
        ghost.Parent = ws
        char.Archivable = false
        
        for _, v in ghost:GetDescendants() do
            if v:IsA("BasePart") then 
                v.Transparency = 0.5 
            elseif v:IsA("Accessory") then
                local handle = v:FindFirstChild("Handle")
                if handle and handle:IsA("BasePart") then
                    handle.Transparency = 0.5
                end
            elseif v:IsA("LocalScript") or v:IsA("Script") then
                v:Destroy()
            end
        end
        
        local gh = ghost:FindFirstChild("Humanoid")
        ghostRoot = ghost:FindFirstChild("HumanoidRootPart")
        
        if gh then 
            cam.CameraSubject = gh 
            gh:SetStateEnabled(Enum.HumanoidStateType.Climbing, true)
        end
        h.PlatformStand = true
        r.CFrame = staticPos
        
        for _, v in char:GetDescendants() do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
        
        loop = rs.Heartbeat:Connect(function(dt)
            local limit = ws.FallenPartsDestroyHeight + 35
            if ghost and ghost.Parent == ws and gh and gh.Health > 0 and ghostRoot and ghostRoot.Position.Y > limit and h and h.Health > 0 then
                
                if cam.CameraSubject ~= gh then
                    cam.CameraSubject = gh
                end

                local currentState = gh:GetState()
                
                if currentState ~= Enum.HumanoidStateType.Climbing then
                    lastSafeCFrame = ghostRoot.CFrame
                    
                    if uis.MouseBehavior == Enum.MouseBehavior.LockCenter then
                        local look = cam.CFrame.LookVector
                        local targetRot = CFrame.lookAt(ghostRoot.Position, ghostRoot.Position + Vector3.new(look.X, 0, look.Z))
                        ghostRoot.CFrame = ghostRoot.CFrame:Lerp(targetRot, math.clamp(dt * 25, 0, 1))
                    end
                end
                
                gh:Move(h.MoveDirection, false)
                gh.Jump = h.Jump
                
                r.CFrame = staticPos
                
                local gv = ghostRoot.AssemblyLinearVelocity
                if gv.Magnitude > 120 then
                    gv = gv.Unit * 120
                end
                
                r.AssemblyLinearVelocity = gv
                r.AssemblyAngularVelocity = ghostRoot.AssemblyAngularVelocity
                
            else
                reset()
            end
        end)
    else
        reset()
    end
end)

lp.CharacterRemoving:Connect(function()
    if active then
        reset()
    end
end)
